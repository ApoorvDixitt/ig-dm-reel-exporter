{
  "manifest_version": 3,
  "name": "DM Shared-Link Extractor",
  "version": "3.1.0",
  "description": "Extract shared reel, post, and carousel links from a Direct thread into a structured JSON for knowledge-base import.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://www.instagram.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [{
    "matches": ["https://www.instagram.com/*"],
    "js": [
      "content/parser.js",
      "content/downloader.js",
      "content/extractor.js",
      "content/content.js"
    ],
    "run_at": "document_idle"
  }],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
