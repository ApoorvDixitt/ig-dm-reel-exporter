{
  "name": "ig-dm-reel-exporter",
  "version": "3.1.2",
  "description": "Chrome MV3 extension that exports reels/posts/carousels shared in an Instagram Direct thread as one structured JSON for knowledge-base import.",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "web-ext run --source-dir=extension --target=chromium",
    "build": "web-ext build --source-dir=extension --artifacts-dir=dist --overwrite-dest",
    "validate": "node -e \"JSON.parse(require('fs').readFileSync('extension/manifest.json','utf8'))\" && find extension -name '*.js' -exec node --check {} +"
  },
  "keywords": [
    "instagram",
    "chrome-extension",
    "manifest-v3",
    "reels",
    "direct-messages",
    "exporter",
    "knowledge-base"
  ],
  "author": "Apoorv Dixit (@ApoorvDixitt)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ApoorvDixitt/ig-dm-reel-exporter.git"
  },
  "bugs": {
    "url": "https://github.com/ApoorvDixitt/ig-dm-reel-exporter/issues"
  },
  "homepage": "https://github.com/ApoorvDixitt/ig-dm-reel-exporter#readme",
  "devDependencies": {
    "web-ext": "^10.5.0"
  }
}
